{
  "description": "Constitutional guardrails for unowned fallbacks, runtime test doubles, hidden owner-layer concepts, and missing boundary witnesses",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 60,
            "statusMessage": "Building witness engine..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-classify.sh",
            "timeout": 20,
            "statusMessage": "Scanning for witness violations..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-audit.sh",
            "async": true,
            "timeout": 300,
            "statusMessage": "Auditing witness constitution (background)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh",
            "timeout": 30,
            "statusMessage": "Checking unresolved witness reports..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh",
            "timeout": 30,
            "statusMessage": "Checking unresolved witness reports..."
          }
        ]
      }
    ]
  }
}
