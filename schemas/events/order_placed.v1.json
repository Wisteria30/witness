{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://witness.local/schemas/events/order_placed.v1.json",
  "title": "OrderPlaced v1",
  "type": "object",
  "required": ["event_id", "order_id", "occurred_at", "line_items"],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sku", "quantity"],
        "properties": {
          "sku": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
